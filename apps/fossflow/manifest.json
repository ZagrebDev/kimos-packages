{
  "id": "fossflow",
  "name": "FossFLOW",
  "version": "2.3.0",
  "description": "Creador de diagramas de flujo isométricos (modelo FossFLOW). Lienzo reactivo y orientado a estado: nodos en grilla (x,y,z) con set de iconos nativo embebido (Lucide) + emojis + importar por URL, y conexiones editables. Editable por el usuario y controlable por un agente autorizado. Soporta ⚙️ Configurar y 🗂️ Documentos (AppShell v2).",
  "icon": "🧊",
  "author": "kimos",
  "entry": "dist/index.js",
  "css": "dist/index.css",
  "appShellApi": "1.x",
  "multiInstance": true,
  "permissions": ["instance.read", "instance.write", "agent.control"],
  "configSchema": {
    "title": "Preferencias de FossFLOW",
    "fields": [
      { "key": "showGrid", "label": "Mostrar líneas de la cuadrícula", "type": "boolean", "help": "Aplica al abrir el diagrama." },
      { "key": "newConnStyle", "label": "Línea de conexiones nuevas", "type": "select", "options": [
        { "value": "solid", "label": "Sólida" },
        { "value": "dashed", "label": "Discontinua" },
        { "value": "dotted", "label": "Punteada" }
      ] },
      { "key": "newConnArrow", "label": "Punta final de conexiones nuevas", "type": "select", "options": [
        { "value": "arrow", "label": "Flecha" },
        { "value": "dot", "label": "Punto" },
        { "value": "none", "label": "Sin punta" }
      ] }
    ]
  },
  "defaultConfig": { "showGrid": true, "newConnStyle": "solid", "newConnArrow": "arrow" }
}
